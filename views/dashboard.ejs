<!DOCTYPE html>
<html>
<head>
    <title>IoT Tracker</title>
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

    <link rel="stylesheet"
    href="https://unpkg.com/leaflet/dist/leaflet.css"/>

    <style>

body{
    background:#0f172a;
    font-family:'Segoe UI',sans-serif;
}

.sidebar{
    position:fixed;
    left:0;
    top:0;
    width:260px;
    height:100vh;
    background:#111827;
    padding:25px;
    color:white;
}

.logo{
    font-size:28px;
    font-weight:bold;
    margin-bottom:40px;
}

.main{
    margin-left:280px;
    padding:25px;
}

.stat-card{
    border:none;
    border-radius:20px;
    color:white;
    transition:.3s;
}

.stat-card:hover{
    transform:translateY(-5px);
}

.total{
    background:linear-gradient(135deg,#2563eb,#1e40af);
}

.online{
    background:linear-gradient(135deg,#10b981,#059669);
}

.offline{
    background:linear-gradient(135deg,#ef4444,#dc2626);
}

.card{
    border:none;
    border-radius:20px;
}

.card-header{
    background:white;
    border:none;
    font-weight:bold;
}

#map{
    height:550px;
    border-radius:15px;
}

.table{
    vertical-align:middle;
}

.table tbody tr:hover{
    background:#f8fafc;
}

.btn{
    border-radius:12px;
}

.maps-btn{
    display:inline-block;
    background:#111827;
    color:white !important;

    text-decoration:none !important;

    padding:8px 14px;
    border-radius:10px;

    font-size:13px;
    font-weight:700;

    transition:.3s;
}

.maps-btn:hover{
    background:#000000;
    color:white !important;

    text-decoration:none !important;

    transform:translateY(-2px);
}
.watermark{
    position:fixed;
    right:20px;
    bottom:20px;
    z-index:9999;

    background:rgba(236,72,153,0.15);
    backdrop-filter:blur(10px);

    border:1px solid rgba(236,72,153,0.4);

    border-radius:18px;

    padding:12px 18px;

    color:#ec4899;

    font-size:13px;
    font-weight:600;

    box-shadow:
        0 0 15px rgba(236,72,153,0.3);

    transition:.3s;
}

.watermark:hover{
    transform:translateY(-5px);
    box-shadow:
        0 0 25px rgba(236,72,153,0.6);
}

/* =========================
   RESPONSIVE MOBILE
========================= */

@media (max-width: 768px){

    .sidebar{
        position:relative;
        width:100%;
        height:auto;
        padding:15px;
    }

    .main{
        margin-left:0;
        padding:10px;
    }

    .logo{
        font-size:22px;
        margin-bottom:15px;
    }

    .container{
        padding-left:0;
        padding-right:0;
    }

    #map{
        height:300px;
    }

    .card{
        margin-bottom:15px;
    }

    .card-body{
        padding:15px;
    }

    .table{
        font-size:13px;
    }

    .btn{
        width:100%;
        margin-bottom:5px;
    }

    .watermark{
        position:relative;
        text-align:center;
        margin-top:20px;
        right:auto;
        bottom:auto;
    }

}
</style>

</head>

<body class="bg-light">
<div class="sidebar">

<div class="logo">
📍 IoT Tracker
</div>

</div>

<div class="main">

<div class="container mt-4">

    <!-- Statistik -->

    <div class="row mb-4">

<div class="col-md-4">

<div class="card stat-card total shadow">

<div class="card-body text-center">

<h1><%= total %></h1>

<p>Total Device</p>

</div>

</div>

</div>

<div class="col-md-4">

<div class="card stat-card online shadow">

<div class="card-body text-center">

<h1><%= online %></h1>

<p>Online</p>

</div>

</div>

</div>

<div class="col-md-4">

<div class="card stat-card offline shadow">

<div class="card-body text-center">

<h1><%= offline %></h1>

<p>Offline</p>

</div>

</div>

</div>

</div>

    <!-- Form Tambah Device -->

    <div class="card shadow mb-4">

        <div class="card-header">
            Tambah Device
        </div>

        <div class="card-body">

            <form action="/add-device" method="POST">

                <input
                type="text"
                name="deviceId"
                class="form-control mb-3"
                placeholder="Device ID">

                <input
                type="text"
                name="nama"
                class="form-control mb-3"
                placeholder="Nama Device">

                <button class="btn btn-primary">
                    Tambah Device
                </button>

            </form>

        </div>

    </div>

    <!-- Peta -->

    <div class="card shadow mb-4">

        <div class="card-header">
            Live Tracking Map
        </div>

        <div class="card-body">

            <div id="map"></div>

        </div>

    </div>

    <!-- Tabel Device -->

    <div class="card shadow">

        <div class="card-header">
            Daftar Device
        </div>

        <div class="card-body">

            <table class="table table-bordered">

                <thead>
                    <tr>
                        <th>Device ID</th>
                        <th>Nama</th>
                        <th>Status</th>
                        <th>Aksi</th>
                        <th>tracker</th>
                    </tr>
                </thead>

                <tbody>

<% devices.forEach(device=>{ %>

<tr>

<td><%= device.deviceId %></td>

<td><%= device.nama %></td>

<td>

<% if(device.status === "Online"){ %>

<span class="badge bg-success">
Online
</span>

<% } else { %>

<span class="badge bg-danger">
Offline
</span>

<% } %>

</td>

<td>

<button
class="btn btn-primary btn-sm"
onclick="copyLink('<%= device.deviceId %>')">

 Copy Link

</button>

<a
href="/delete-device/<%= device._id %>"
class="btn btn-danger btn-sm"
onclick="return confirm('Hapus device?')">

 Delete

</a>

</td>

<td>

<a
href="/tracker/<%= device.deviceId %>"
class="btn btn-success">

📍 Tracker

</a>

</td>

</tr>

<% }) %>

</tbody>

            </table>

        </div>

    </div>

</div>

<script>

function copyLink(deviceId){

const link =
window.location.origin +
"/tracker/" +
deviceId;

navigator.clipboard.writeText(link);

alert("Link tracker berhasil disalin");

}

</script>

<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>

<script>
document.addEventListener("DOMContentLoaded", function(){

    const map = L.map("map").setView([-7.2575,112.7521],13);

    L.tileLayer(
        "https://tile.openstreetmap.org/{z}/{x}/{y}.png",
        {
            maxZoom:19
        }
    ).addTo(map);

    const devices = JSON.parse(
    '<%- devicesJson %>'
);

    devices.forEach(device => {

        if(device.latitude && device.longitude){

            L.marker([
                device.latitude,
                device.longitude
            ])
            .addTo(map)
            .bindPopup(
    "<b>" + device.nama + "</b><br>" +
    "Device : " + device.deviceId + "<br>" +
    "Status : " + device.status + "<br><br>" +

    "<a target='_blank' " +
"href='https://www.google.com/maps?q=" +
device.latitude + "," +
device.longitude +
"' class='maps-btn'>" +

"📍 Buka di Google Maps" +

"</a>"
);

        }

    });

});
</script>
</div>

<div class="watermark">

<div style="font-size:18px;">

</div>

<div>
<b>Richad</b>
</div>

<div style="font-size:11px;">
PBL IoT Tracking System
</div>

</div>
</body>
</html>
